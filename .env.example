# Copy this file to .env and fill in values as needed.
# NONE of the currently-verified data sources require an API key (all are
# public, unauthenticated ArcGIS REST endpoints). This file is provided so
# the system has a clean place to add credentials if you later add a source
# that requires one (e.g. a Socrata app token for a future St. Petersburg
# integration, or an Accela "AA" API agreement for Pasco/Clearwater/Bradenton).

# Optional: Socrata app token (raises rate limits if a jurisdiction later
# publishes an open-data Socrata endpoint). Leave blank if unused.
SOCRATA_APP_TOKEN=

# Optional: outbound webhook/email for run-failure alerts (used by
# core/logging_utils.py if ALERT_WEBHOOK_URL is set; safe to leave blank).
ALERT_WEBHOOK_URL=

# Optional: override the output data directory (defaults to ./data)
DATA_DIR=

# Optional: override log level (DEBUG, INFO, WARNING, ERROR). Default INFO.
LOG_LEVEL=INFO
